{
  "license": "ISC",
  "type": "module",
  "scripts": {
    "surfpool": "surfpool start --no-tui",
    "surfpool:offline": "surfpool start --no-tui --offline --no-studio",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "generate-merkle-tree": "ts-node utils/GenerateMerkleTree.ts",
    "deploy:devnet": "anchor build && anchor deploy --provider.cluster devnet --program-name capstone_escrow",
    "test:capstone:local": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=$HOME/.config/solana/id.json ts-mocha -p ./tsconfig.json tests/capstone.ts --skip-local-validator",
    "test:capstone:devnet": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=$HOME/.config/solana/id.json ts-mocha -p ./tsconfig.json tests/capstone.devnet.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "merkletreejs": "^0.6.0",
    "papaparse": "^5.5.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^25.2.2",
    "@types/papaparse": "^5",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
